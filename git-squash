#!/bin/bash

HOW_MANY_COMMITS=${1:?"Usage: $(basename $0) <commits_to_squash>"}

if ! [[ "$HOW_MANY_COMMITS" =~ ^[1-9][0-9]*$ ]]; then
  echo "error: argument must be a positive integer" >&2
  exit 1
fi

# If input is large number, then double check before we continue
if [ "$HOW_MANY_COMMITS" -gt 5 ]; then
  read -r -p "About to squash $HOW_MANY_COMMITS commits. Are you sure? [y/N] " confirm
  [[ "$confirm" =~ ^[Yy]$ ]] || exit 0
fi

git reset --soft HEAD~${HOW_MANY_COMMITS} && 
git commit --edit -m"$(git log --format=%B --reverse HEAD..HEAD@{1})"

