#!/bin/bash
set -eu

## roll back N commits (1 commit by default) and reset the current changeset to look clean

RUN_COUNT=${1:-1}

if ! [[ "$RUN_COUNT" =~ ^[1-9][0-9]*$ ]]; then
  echo "error: argument must be a positive integer" >&2
  exit 1
fi

# If input is large number, then double check before we continue
if [ "$RUN_COUNT" -gt 15 ]; then
  read -r -p "About to undo $RUN_COUNT commits. Are you sure? [y/N] " confirm
  [[ "$confirm" =~ ^[Yy]$ ]] || exit 0
fi

mkdir -p ~/.git_tools_tmp/

git log -$RUN_COUNT --pretty=%B > ~/.git_tools_tmp/last_commit_message

git reset --soft HEAD~$RUN_COUNT
git reset .
